# Force LF everywhere — this repo is edited on Windows but executed on
# Linux (ubuntu1). Shell scripts + systemd units break with CRLF.
* text=auto eol=lf

*.sh        text eol=lf
*.py        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.xml       text eol=lf
*.service   text eol=lf
*.cfg       text eol=lf
*.md        text eol=lf
